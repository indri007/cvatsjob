# OpenAI API Key (required for AI features)
OPENAI_API_KEY=sk-your-key-here

# Database (default: local SQLite)
# For Aiven MySQL, Aiven requires SSL. Format:
# mysql+pymysql://avnadmin:PASSWORD@HOST:PORT/defaultdb?ssl_ca=./ca.pem
# (download ca.pem from Aiven Console -> your service -> Overview -> "CA certificate")
DATABASE_URL=sqlite:///data/jobs.db

# Vector Store (default: local ChromaDB)
# For Qdrant Cloud:
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your-qdrant-api-key
VECTOR_STORE=chromadb
CHROMA_PERSIST_DIR=data/chroma_db

# Embedding Model (default: local sentence-transformers)
# Set to "openai" to use OpenAI embeddings
EMBEDDING_MODEL=local

# N8N Webhook (for production)
# N8N_WEBHOOK_URL=https://your-n8n.app/webhook/xxx
